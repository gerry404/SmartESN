# --- Secrets & config pour docker compose (copiez en .env et remplissez) ---

# Base de données
DB_PASSWORD=changez_ce_mot_de_passe

# Sécurité JWT (chaîne aléatoire >= 32 caractères)
JWT_SECRET=changez_cette_cle_secrete_de_32_caracteres_min
JWT_EXPIRATION_MS=86400000

# Fournisseur LLM (API compatible OpenAI)
LLM_API_URL=https://openrouter.ai/api/v1/chat/completions
LLM_API_KEY=votre_cle_llm
LLM_MODEL=mistralai/mistral-small-3.2-24b-instruct
LLM_VISION_MODEL=openai/gpt-4o-mini

# --- URLs (adaptez selon local ou production) ---
# En LOCAL (docker compose sur votre machine) :
#   admin  → http://localhost:8081
#   client → http://localhost:4200
#   backend→ http://localhost:8080
PUBLIC_API_URL=http://localhost:8080
FORM_BASE_URL=http://localhost:4200
CORS_ORIGINS=http://localhost:8081,http://localhost:4200

# En PRODUCTION, remplacez par vos vrais domaines, ex :
#   PUBLIC_API_URL=https://api.smartesn.com
#   FORM_BASE_URL=https://form.smartesn.com
#   CORS_ORIGINS=https://app.smartesn.com,https://form.smartesn.com
